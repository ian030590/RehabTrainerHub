{
  "name": "@rehab-trainer/motortrainer",
  "private": true,
  "version": "3.0.0",
  "homepage": "https://motor.trainerhub.cc",
  "rehabTrainer": {
    "role": "trainer"
  },
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node ../../scripts/check-trainer-entrypoints.mjs && tsc -b && vite build && node ../../scripts/check-vite-html-shell.mjs dist/index.html && npm run test:asteroid-shield-fullscreen && node scripts/prune-cloudflare-pages-assets.mjs && npm run test:browser-shell",
    "build:full": "node ../../scripts/check-trainer-entrypoints.mjs && tsc -b && vite build && node ../../scripts/check-vite-html-shell.mjs dist/index.html && npm run test:asteroid-shield-fullscreen && npm run test:browser-shell",
    "build:cloudflare": "node ../../scripts/check-trainer-entrypoints.mjs && tsc -b && vite build --mode cloudflare && node ../../scripts/check-vite-html-shell.mjs dist/index.html && npm run test:asteroid-shield-fullscreen && node scripts/prune-cloudflare-pages-assets.mjs --force && npm run test:browser-shell",
    "test:entrypoints": "node ../../scripts/check-trainer-entrypoints.mjs",
    "test:production-shell": "node ../../scripts/check-vite-html-shell.mjs dist/index.html",
    "test:browser-shell": "node ../../scripts/check-browser-route-smoke.mjs --app . --route / --selector .training-grid --mockAuthUser true",
    "test:asteroid-shield-fullscreen": "node ../../scripts/check-browser-route-smoke.mjs --app . --route /#/upper-limb-training?game=asteroid-shield --mockAuthUser true --clickSelectors \".asteroid-shield-phase-menu .asteroid-shield-hand-control-off,.asteroid-shield-phase-menu .config-start-btn,.asteroid-shield-phase-rules .config-start-btn\" --selector .asteroid-shield-phase-playing --fullscreenSelector .asteroid-shield-game --fullscreenBeforeAudio true --viewportSelectors \".asteroid-shield-game,.asteroid-shield-stage\" --canvasViewportSelectors .asteroid-shield-canvas",
    "r2:upload-vosk": "node scripts/upload-vosk-to-r2.mjs",
    "vosk:repair-zh-symbols": "node scripts/repair-zh-vosk-symbols.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "@tensorflow-models/knn-classifier": "^1.2.6",
    "@tensorflow/tfjs": "^4.22.0",
    "jspsych": "^8.2.1",
    "pinyin-pro": "^3.28.1",
    "pixi.js": "^8.18.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",
    "recharts": "^3.8.1",
    "three": "^0.184.0",
    "vosk-browser": "^0.0.8"
  },
  "devDependencies": {
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.5.2",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
