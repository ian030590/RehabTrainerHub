{
  "name": "rehab-workspace",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "npm@11.18.0",
  "description": "Turborepo monorepo for RehabTrainerHub, StrokeTrainer, and VisionTrainer.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "node scripts/build-apps.mjs",
    "build:hub": "npm --prefix apps/rehabtrainerhub run build",
    "build:stroke": "npm --prefix apps/stroketrainer run build",
    "build:vision": "npm --prefix apps/visiontrainer run build",
    "build:turbo": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:hub": "turbo run dev --filter=@rehab-trainer/rehabtrainerhub",
    "dev:stroke": "turbo run dev --filter=@rehab-trainer/stroketrainer",
    "dev:vision": "turbo run dev --filter=@rehab-trainer/visiontrainer",
    "preview:hub": "turbo run preview --filter=@rehab-trainer/rehabtrainerhub",
    "preview:stroke": "turbo run preview --filter=@rehab-trainer/stroketrainer",
    "preview:vision": "turbo run preview --filter=@rehab-trainer/visiontrainer"
  },
  "dependencies": {
    "@jspsych/extension-webgazer": "^1.2.0",
    "@jspsych/plugin-html-button-response": "^2.1.0",
    "@jspsych/plugin-webgazer-calibrate": "^2.1.0",
    "@jspsych/plugin-webgazer-init-camera": "^2.1.0",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@tensorflow-models/knn-classifier": "^1.2.6",
    "@tensorflow/tfjs": "^4.22.0",
    "jspsych": "^8.2.1",
    "next": "^16.2.10",
    "pinyin-pro": "^3.28.1",
    "pixi.js": "^8.18.1",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",
    "recharts": "^3.8.1",
    "three": "^0.184.0",
    "vosk-browser": "^0.0.8"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.3",
    "turbo": "^2.10.2",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=22"
  }
}
