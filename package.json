{
  "name": "rehab-workspace",
  "private": true,
  "version": "1.0.0",
  "license": "AGPL-3.0-only",
  "type": "module",
  "packageManager": "npm@11.18.0",
  "description": "Turborepo monorepo for RehabTrainerHub and its trainer applications.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run test:naming && npm run test:entrypoints && node scripts/build-apps.mjs",
    "build:cloudflare": "npm run test:naming && npm run test:entrypoints && npm run test:cloudflare-deploy && npm run test:changed-trainer-smoke && node scripts/build-apps.mjs --cloudflare-pages",
    "build:brain": "npm --prefix apps/braintrainer run build",
    "build:hub": "npm --prefix apps/rehabtrainerhub run build",
    "build:mouth": "npm --prefix apps/mouthtrainer run build",
    "build:motor": "npm --prefix apps/motortrainer run build",
    "build:vision": "npm --prefix apps/visiontrainer run build",
    "build:turbo": "npm run test:entrypoints && turbo run build",
    "dev": "turbo run dev",
    "dev:brain": "turbo run dev --filter=@rehab-trainer/braintrainer",
    "dev:hub": "turbo run dev --filter=@rehab-trainer/rehabtrainerhub",
    "dev:mouth": "turbo run dev --filter=@rehab-trainer/mouthtrainer",
    "dev:motor": "turbo run dev --filter=@rehab-trainer/motortrainer",
    "dev:vision": "turbo run dev --filter=@rehab-trainer/visiontrainer",
    "deploy:cloudflare": "npm run build:cloudflare && node scripts/deploy-cloudflare-pages.mjs",
    "preview:brain": "turbo run preview --filter=@rehab-trainer/braintrainer",
    "preview:hub": "turbo run preview --filter=@rehab-trainer/rehabtrainerhub",
    "preview:mouth": "turbo run preview --filter=@rehab-trainer/mouthtrainer",
    "preview:motor": "turbo run preview --filter=@rehab-trainer/motortrainer",
    "preview:vision": "turbo run preview --filter=@rehab-trainer/visiontrainer",
    "test:entrypoints": "node scripts/check-trainer-entrypoints.mjs",
    "test:cloudflare-deploy": "node scripts/check-cloudflare-pages-deploy.mjs",
    "test:changed-trainer-smoke": "node scripts/check-changed-trainer-smoke.test.mjs",
    "test:naming": "node scripts/check-identifier-names.mjs"
  },
  "dependencies": {
    "@jspsych/extension-webgazer": "^1.2.0",
    "@jspsych/plugin-html-button-response": "^2.1.0",
    "@jspsych/plugin-webgazer-calibrate": "^2.1.0",
    "@jspsych/plugin-webgazer-init-camera": "^2.1.0",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@tensorflow-models/knn-classifier": "^1.2.6",
    "@tensorflow/tfjs": "^4.22.0",
    "jspsych": "^8.2.1",
    "next": "^16.2.10",
    "pinyin-pro": "^3.28.1",
    "pixi.js": "^8.18.1",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",
    "recharts": "^3.8.1",
    "three": "^0.184.0",
    "vosk-browser": "^0.0.8"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.5.2",
    "turbo": "^2.10.2",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  },
  "engines": {
    "node": ">=22"
  }
}
